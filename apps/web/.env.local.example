# =========================================
# apps/web — variáveis locais
# Copie para .env.local e preencha.
# =========================================
#
# --- Vercel / CI ---
# O build roda validação em src/env.ts. Na Vercel não existe .env.local:
# Project → Settings → Environment Variables → cadastre TODAS as chaves
# obrigatórias abaixo (Production + Preview). Sem isso, next build falha.
#
# NEXT_PUBLIC_SITE_URL na Preview pode ser a URL automática do deploy
# (ex.: https://seu-proj.vercel.app). Em Production use o domínio final.
#
# Somente para debug de build (evita validação — não use em prod real):
# SKIP_ENV_VALIDATION=true
#

# URL pública canônica do site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp da loja (E.164 sem +)
NEXT_PUBLIC_WHATSAPP_NUMBER=5577988018192

# Telefone fixo
NEXT_PUBLIC_PHONE=557732621344

# ============== ERP ==============
ERP_API_URL=https://app.oticasqueiroz.com.br
ERP_API_KEY=replace-me

# ============== AUTH ==============
# Mínimo 32 caracteres (ver src/env.ts). Gerar com: openssl rand -base64 32
AUTH_SECRET=01234567890123456789012345678901

# ============== Rate Limit ==============
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============== Observabilidade ==============
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============== Analytics ==============
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=oticasqueiroz.com.br
