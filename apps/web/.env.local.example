# =========================================
# apps/web — variáveis locais
# Copie para .env.local e preencha.
# =========================================

# URL pública canônica do site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp da loja (E.164 sem +)
NEXT_PUBLIC_WHATSAPP_NUMBER=5577988018192

# Telefone fixo
NEXT_PUBLIC_PHONE=557732621344

# ============== ERP ==============
ERP_API_URL=https://app.oticasqueiroz.com.br
ERP_API_KEY=replace-me

# ============== AUTH ==============
# Gerar com: openssl rand -base64 32
AUTH_SECRET=replace-me

# ============== Rate Limit ==============
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============== Observabilidade ==============
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============== Analytics ==============
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=oticasqueiroz.com.br
