# =========================================
# infra/n8n — variáveis do docker-compose
# Copie para .env e preencha. NÃO commitar.
# =========================================

# Postgres do n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-me-strong-password
POSTGRES_DB=n8n

# n8n
N8N_HOST=automacao.oticasqueiroz.com.br
# Gere com: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-me-32-char-hex

# Integração com ERP
ERP_API_URL=https://app.oticasqueiroz.com.br
ERP_API_KEY=replace-me
